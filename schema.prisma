import { prisma } from "@/lib/prisma";

export async function sendPreRegistrationWhatsApp(preRegistrationId: string) {
  const registration = await prisma.preRegistration.findUnique({
    where: { id: preRegistrationId },
    include: { preferredGroup: true },
  });
  if (!registration) return { ok: false, status: "FAILED", error: "Ön kayıt bulunamadı." };

  const token = process.env.WHATSAPP_ACCESS_TOKEN;
  const phoneNumberId = process.env.WHATSAPP_PHONE_NUMBER_ID;
  const recipient = process.env.WHATSAPP_NOTIFICATION_PHONE?.replace(/\D/g, "");
  const version = process.env.WHATSAPP_GRAPH_API_VERSION;
  if (!token || !phoneNumberId || !recipient || !version) {
    await prisma.preRegistration.update({
      where: { id: registration.id },
      data: { whatsappStatus: "NOT_CONFIGURED", whatsappError: "WhatsApp Business ayarları eksik." },
    });
    return { ok: false, status: "NOT_CONFIGURED", error: "WhatsApp Business ayarları eksik." };
  }

  const studentName = `${registration.studentFirstName} ${registration.studentLastName}`;
  const groupName = registration.preferredGroup?.name ?? "Belirtilmedi";
  const message = `Yeni Sümbülspor Akademi ön kaydı\n\nSporcu: ${studentName}\nDoğum tarihi: ${registration.birthDate.toLocaleDateString("tr-TR")}\nTercih edilen grup: ${groupName}\nVeli: ${registration.parentName}\nTelefon: ${registration.parentPhone}\nE-posta: ${registration.parentEmail || "Belirtilmedi"}`;
  const templateName = process.env.WHATSAPP_TEMPLATE_NAME;
  const payload = templateName ? {
    messaging_product: "whatsapp",
    to: recipient,
    type: "template",
    template: {
      name: templateName,
      language: { code: process.env.WHATSAPP_TEMPLATE_LANGUAGE || "tr" },
      components: [{ type: "body", parameters: [
        { type: "text", text: studentName },
        { type: "text", text: registration.parentName },
        { type: "text", text: registration.parentPhone },
        { type: "text", text: groupName },
      ] }],
    },
  } : { messaging_product: "whatsapp", recipient_type: "individual", to: recipient, type: "text", text: { preview_url: false, body: message } };

  try {
    const response = await fetch(`https://graph.facebook.com/${version}/${phoneNumberId}/messages`, {
      method: "POST",
      headers: { Authorization: `Bearer ${token}`, "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const result = await response.json() as { messages?: Array<{ id: string }>; error?: { message?: string } };
    if (!response.ok) throw new Error(result.error?.message || `WhatsApp API hatası: ${response.status}`);
    const messageId = result.messages?.[0]?.id;
    await prisma.preRegistration.update({
      where: { id: registration.id },
      data: { whatsappStatus: "SENT", whatsappMessageId: messageId, whatsappError: null, whatsappSentAt: new Date() },
    });
    return { ok: true, status: "SENT", messageId };
  } catch (error) {
    const errorMessage = error instanceof Error ? error.message : "WhatsApp bildirimi gönderilemedi.";
    await prisma.preRegistration.update({ where: { id: registration.id }, data: { whatsappStatus: "FAILED", whatsappError: errorMessage.slice(0, 500) } });
    return { ok: false, status: "FAILED", error: errorMessage };
  }
}
