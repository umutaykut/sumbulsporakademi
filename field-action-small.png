import { createPreRegistrationAction } from "@/app/actions";
import { prisma } from "@/lib/prisma";
import Link from "next/link";

export const dynamic = "force-dynamic";

export default async function PreRegistration({ searchParams }: { searchParams: Promise<{ basarili?: string; hata?: string; kayit?: string }> }) {
  const q = await searchParams;
  const groups = await prisma.group.findMany({ orderBy: { ageMin: "asc" } });
  const registration = q.kayit ? await prisma.preRegistration.findUnique({ where: { id: q.kayit }, select: { id:true,studentFirstName:true,studentLastName:true,parentName:true,parentPhone:true } }) : null;
  const whatsappPhone = process.env.WHATSAPP_NOTIFICATION_PHONE?.replace(/\D/g, "");
  const whatsappMessage = registration ? `Merhaba, Sümbülspor Akademi ön kayıt formunu doldurdum.\n\nBaşvuru no: ${registration.id}\nSporcu: ${registration.studentFirstName} ${registration.studentLastName}\nVeli: ${registration.parentName}\nTelefon: ${registration.parentPhone}\n\nBaşvurumun değerlendirilmesini rica ederim.` : "";
  const whatsappUrl = registration && whatsappPhone ? `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(whatsappMessage)}` : null;
  return <main style={{minHeight:"100vh",background:"var(--cream)"}}>
    <header style={{background:"var(--navy)",color:"white",padding:"16px 24px"}}><div className="row between" style={{maxWidth:1100,margin:"auto"}}><Link className="brand" href="/on-kayit"><span className="brand-mark">⚽</span><span>Sümbülspor Akademi</span></Link><Link className="button secondary small" href="/login">Hesabım</Link></div></header>
    <div className="main" style={{maxWidth:900}}>
      <div style={{textAlign:"center",marginBottom:24}}><div className="eyebrow">Akademiye ilk adım</div><h1 className="title">Sporcu ön kayıt formu</h1><p className="muted">Başvurunuz koordinatör tarafından incelendikten sonra sizinle iletişime geçilecektir.</p></div>
      {q.basarili && <div className="card" style={{marginBottom:18,textAlign:"center"}}><div style={{fontSize:42}}>✓</div><h2>Ön kaydınız alındı</h2><p className="muted">Başvurunuz koordinatör paneline kaydedildi. Şimdi hazırlanan mesajı WhatsApp üzerinden koordinatörümüze iletebilirsiniz.</p>{whatsappUrl ? <a className="button" href={whatsappUrl} target="_blank" rel="noopener noreferrer" style={{background:"#168b4c",fontSize:16,padding:"14px 22px"}}>WhatsApp'ı aç ve mesajı gönder</a> : <div className="notice">Koordinatör WhatsApp numarası henüz tanımlanmadı. Başvurunuz yine de başarıyla kaydedildi.</div>}<div className="footer-note">WhatsApp açıldıktan sonra mesajı göndermek için son kez “Gönder” düğmesine basmanız gerekir.</div></div>}
      {q.hata && <div className="notice" style={{marginBottom:18}}>{q.hata}</div>}
      <section className="card"><form action={createPreRegistrationAction} className="form-grid">
        <div style={{position:"absolute",left:"-10000px"}} aria-hidden="true"><label>Web sitesi<input name="website" tabIndex={-1} autoComplete="off"/></label></div>
        <div className="field"><label>Sporcu adı *</label><input className="input" name="studentFirstName" required/></div>
        <div className="field"><label>Sporcu soyadı *</label><input className="input" name="studentLastName" required/></div>
        <div className="field"><label>Doğum tarihi *</label><input className="input" type="date" name="birthDate" required/></div>
        <div className="field"><label>Tercih edilen yaş grubu</label><select className="input" name="preferredGroupId"><option value="">Koordinatör belirlesin</option>{groups.map(group => <option value={group.id} key={group.id}>{group.name}</option>)}</select></div>
        <div className="field"><label>Veli adı soyadı *</label><input className="input" name="parentName" required/></div>
        <div className="field"><label>Veli telefon numarası *</label><input className="input" type="tel" name="parentPhone" required placeholder="05xx xxx xx xx"/></div>
        <div className="field full"><label>Veli e-posta</label><input className="input" type="email" name="parentEmail"/></div>
        <div className="field full"><label>Eklemek istediğiniz not</label><textarea className="input" name="note" maxLength={500} placeholder="Tercih edilen günler veya koordinatöre iletmek istediğiniz kısa bilgi"/></div>
        <label className="row field full" style={{alignItems:"flex-start"}}><input type="checkbox" name="consentAccepted" required style={{marginTop:4}}/><span>Paylaştığım bilgilerin ön kayıt başvurusunun değerlendirilmesi ve benimle iletişime geçilmesi amacıyla işlenmesini kabul ediyorum. *</span></label>
        <div className="field full"><button className="button" style={{width:"100%"}}>Ön kaydı gönder</button></div>
      </form></section>
    </div>
  </main>;
}
